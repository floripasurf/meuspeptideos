generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// PUBLIC: Peptide Knowledge Base
// ============================================

model Peptide {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  aliases       String[] // ex: ["Ozempic", "Wegovy"] para semaglutida
  category      PeptideCategory
  description   String // o que é, resumo
  mechanism     String // mecanismo de ação detalhado
  researchPhase ResearchPhase
  anvisaStatus  RegulatoryStatus @default(not_regulated)
  fdaStatus     RegulatoryStatus @default(not_regulated)
  emaStatus     RegulatoryStatus @default(not_regulated)
  benefits      Json // [{name, evidence: "proven"|"research"|"unproven", description, studyUrl}]
  risks         Json // [{name, severity: "low"|"medium"|"high", frequency, description, studyUrl}]
  internetVsScience Json // [{claim, whatTheySay, actualEvidence, verdict: "true"|"partial"|"false"|"unknown"}]
  published     Boolean  @default(false)
  publishedAt   DateTime?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
  studies       Study[]
  faqs          PeptideFaq[]
}

model Study {
  id          String    @id @default(cuid())
  peptideId   String
  peptide     Peptide   @relation(fields: [peptideId], references: [id], onDelete: Cascade)
  title       String
  authors     String
  journal     String
  year        Int
  pubmedId    String? // PubMed ID para link direto
  doi         String?
  abstract    String?
  keyFindings String // resumo em português dos achados principais
  studyType   StudyType
  sampleSize  Int?
  url         String
  createdAt   DateTime  @default(now())
}

model PeptideFaq {
  id        String  @id @default(cuid())
  peptideId String
  peptide   Peptide @relation(fields: [peptideId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  order     Int     @default(0)
}

model BlogPost {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  content      String
  excerpt      String
  author       String
  reviewerName String? // "Dr. Fulano"
  reviewerCrm  String? // "CRM 12345"
  published    Boolean   @default(false)
  publishedAt  DateTime?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())
  tags         String[]
}

// ============================================
// LEAD CAPTURE + MARKET INTELLIGENCE
// ============================================

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  whatsapp  String?
  city      String?
  state     String?
  lat       Float?
  lng       Float?
  interests String[] // slugs dos peptídeos de interesse
  source    String // blog, peptide_page, newsletter, quiz
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Lead {
  id              String     @id @default(cuid())
  name            String?
  email           String?
  whatsapp        String?
  city            String?
  state           String?
  lat             Float?
  lng             Float?
  peptideInterest String[] // slugs dos peptídeos
  sourcePage      String // URL da página que gerou o lead
  contactMethod   String // whatsapp, form, quiz
  status          LeadStatus @default(new)
  clinicId        String? // clínica atribuída (match geográfico)
  clinic          Clinic?    @relation(fields: [clinicId], references: [id])
  notes           String?
  consentDoctorShare   Boolean   @default(false) // autorizou compartilhar dados com medico parceiro
  consentDoctorShareAt DateTime?
  submittedFromIp      String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deliveries      LeadDelivery[]

  @@index([submittedFromIp, createdAt])
}

// ============================================
// INTERNAL ONLY: Secret Clinic Catalog
// Never exposed publicly. These are our future clients.
// ============================================

model Clinic {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  googlePlaceId String?  @unique
  address       String
  city          String
  state         String
  neighborhood  String?
  lat           Float?
  lng           Float?
  phone         String?
  whatsapp      String?
  website       String?
  googleMapsUrl String?
  googleRating  Float?
  googleReviews Int?
  specialties   String[] // ex: ["semaglutida", "medicina funcional"]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  leads         Lead[]
  isPublic     Boolean   @default(false) // aparece no diretório público
  premiumUntil DateTime? // assinatura de destaque ativa até
  bookingUrl   String? // link de agendamento exibido no diretório
}

// Farmácias de manipulação parceiras — recebem pedidos de orçamento, pagam comissão
model Pharmacy {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  email           String // recebe os pedidos de orçamento
  whatsapp        String?
  city            String?
  state           String?
  shipsNationwide Boolean  @default(true)
  compounds       String[] // slugs que manipula; vazio = todos
  commissionPct   Float    @default(10) // % sobre pedido convertido
  leadPrice       Float? // alternativa: preço fixo por lead (R$)
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  quotes          QuoteRequest[]
}

model QuoteRequest {
  id              String      @id @default(cuid())
  name            String
  email           String?
  whatsapp        String
  city            String?
  state           String?
  compoundSlug    String
  hasPrescription Boolean     @default(false)
  message         String?
  sourcePage      String
  consentLgpd     Boolean     @default(false)
  submittedFromIp String?
  status          QuoteStatus @default(new)
  pharmacyId      String?
  pharmacy        Pharmacy?   @relation(fields: [pharmacyId], references: [id])
  sentAt          DateTime?
  orderValue      Float? // valor do pedido reportado pela farmácia
  commissionValue Float? // comissão devida/registrada
  paidAt          DateTime? // comissão recebida
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum QuoteStatus {
  new
  sent
  quoted
  converted
  paid
  lost
}

// Entrega de lead a um médico (Receita B) — registro de cobrança
model LeadDelivery {
  id          String    @id @default(cuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id])
  doctorId    String
  doctor      Doctor    @relation(fields: [doctorId], references: [id])
  price       Float // R$ combinado por lead
  deliveredAt DateTime  @default(now())
  paidAt      DateTime?
  notes       String?

  @@unique([leadId, doctorId])
}

// Doctors who self-register to receive leads
// Private — discreet, never exposed publicly
model Doctor {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String? // telefone fixo / consultório
  whatsapp     String?
  crm          String? // CRM number
  crmState     String? // CRM state
  specialty    String? // endocrinologia, medicina funcional, etc.
  address      String? // endereço completo do consultório
  city         String?
  state        String?
  peptidesPrescribed String[] // slugs dos peptídeos que prescreve
  yearsExperience Int?
  acceptsPartnership Boolean @default(true) // aceita parceria de leads
  notes        String? // notas internas
  emailVerified    Boolean   @default(false) // verificou email?
  verificationToken String?  @unique // token único para verificação
  verifiedAt       DateTime? // quando confirmou
  consentLgpd      Boolean   @default(false) // consentiu com política LGPD
  consentLgpdAt    DateTime? // quando consentiu
  submittedFromIp  String?   // IP de cadastro (rate limiting + audit)
  verified     Boolean  @default(false) // verificação manual pela admin
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deliveries   LeadDelivery[]

  @@index([submittedFromIp, createdAt])
}

// Rate limit tracking for public endpoints
model RateLimitEntry {
  id        String   @id @default(cuid())
  ip        String
  endpoint  String // ex: "doctor_signup", "lead_capture"
  createdAt DateTime @default(now())

  @@index([ip, endpoint, createdAt])
}

// ============================================
// ENUMS
// ============================================

enum PeptideCategory {
  glp1
  growth_hormone
  healing
  neuroprotective
  cosmetic
  immune
  performance
  longevity
}

enum ResearchPhase {
  preclinical // só estudos in vitro / animal
  phase1      // segurança em humanos
  phase2      // eficácia inicial
  phase3      // eficácia confirmada
  approved    // aprovado por agência reguladora
}

enum RegulatoryStatus {
  approved
  pending
  not_regulated
  banned
  compounding_only // permitido via farmácia de manipulação
}

enum StudyType {
  meta_analysis
  systematic_review
  rct // randomized controlled trial
  cohort
  case_study
  review
  animal
  in_vitro
}

enum LeadStatus {
  new
  contacted
  matched    // conectado a uma clínica
  converted  // virou paciente
  lost
}
